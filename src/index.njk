---
layout: base.njk
---
{# All projects sorted by order #}
{% set allProjects = collections.projects %}
{% set letters = collections.letters %}

{# Distribute projects into three independent columns #}
{% set leftProjects = [] %}
{% set centerProjects = [] %}
{% set rightProjects = [] %}
{% for p in allProjects %}
  {% set col = loop.index0 % 3 %}
  {% if col == 0 %}{% set leftProjects = (leftProjects.push(p), leftProjects) %}
  {% elif col == 1 %}{% set centerProjects = (centerProjects.push(p), centerProjects) %}
  {% else %}{% set rightProjects = (rightProjects.push(p), rightProjects) %}
  {% endif %}
{% endfor %}

{# Macro for rendering a thumbnail (image or video) #}
{% macro thumb(p) %}
  {% if p.data.thumbnail_video_url %}
    <div class="story-video-thumb"><iframe src="{{ p.data.thumbnail_video_url | videoEmbed }}?autoplay=1&mute=1&loop=1&playlist={{ p.data.thumbnail_video_url | videoId }}&controls=0&playsinline=1&rel=0&showinfo=0&modestbranding=1" frameborder="0" allow="autoplay; encrypted-media" loading="lazy"></iframe></div>
  {% else %}
    <img class="story-image {% if p.data.thumbnail_aspect == 'portrait' %}portrait{% elif p.data.thumbnail_aspect == 'square' %}square{% endif %}" src="{{ p.data.thumbnail }}" alt="{{ p.data.title }}">
  {% endif %}
{% endmacro %}

<div class="front-page" id="frontPage">
  <header class="masthead">
    <svg class="masthead-svg" onclick="window.scrollTo({top:0,behavior:'smooth'})" viewBox="0 0 452.04 41.89" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Ethan Jack Smithe Byrne">{% include "masthead-inner.svg" %}</svg>
    <div class="masthead-subtitle">{{ site.subtitle }}</div>
  </header>

  <div class="dateline-bar">
    <span><a href="/about/">About</a> · <a href="mailto:{{ site.email }}">Contact</a> · <a href="https://instagram.com/{{ site.instagram }}" target="_blank">Instagram</a></span>
    <span id="currentDate"></span>
    <span class="dateline-stars">★★★★ $2.00</span>
  </div>

  <div class="ticker-bar" id="tickerBar">
    <div class="ticker-item"><span class="ticker-label">DJIA</span> <span class="ticker-val" id="t-DIA">—</span> <span class="ticker-chg" id="tc-DIA"></span></div>
    <div class="ticker-item"><span class="ticker-label">NASDAQ</span> <span class="ticker-val" id="t-QQQ">—</span> <span class="ticker-chg" id="tc-QQQ"></span></div>
    <div class="ticker-item"><span class="ticker-label">S&amp;P 500</span> <span class="ticker-val" id="t-SPY">—</span> <span class="ticker-chg" id="tc-SPY"></span></div>
    <div class="ticker-item"><span class="ticker-label">10-YR TREAS</span> <span class="ticker-val" id="t-TLT">—</span> <span class="ticker-chg" id="tc-TLT"></span></div>
    <div class="ticker-item"><span class="ticker-label">OIL</span> <span class="ticker-val" id="t-USO">—</span> <span class="ticker-chg" id="tc-USO"></span></div>
    <div class="ticker-item"><span class="ticker-label">GOLD</span> <span class="ticker-val" id="t-GLD">—</span> <span class="ticker-chg" id="tc-GLD"></span></div>
    <div class="ticker-item"><span class="ticker-label">EURO</span> <span class="ticker-val" id="t-FXE">—</span> <span class="ticker-chg" id="tc-FXE"></span></div>
    <div class="ticker-item"><span class="ticker-label">YEN</span> <span class="ticker-val" id="t-FXY">—</span> <span class="ticker-chg" id="tc-FXY"></span></div>
  </div>

  {# ============ THREE INDEPENDENT COLUMNS ============ #}
  <div class="newspaper-grid">

    {# ——— LEFT COLUMN ——— #}
    <div class="col col-left">
      {% for p in leftProjects %}
        {% set idx = loop.index0 * 3 %}
        {% set variant = loop.index0 % 3 %}

        {% if variant == 0 %}
        <div class="story" onclick="openDetail({{ idx }})">
          <div class="story-kicker">{{ p.data.kicker }}</div>
          {{ thumb(p) }}
          <div class="story-headline md">{{ p.data.title }}</div>
          <div class="story-byline">{{ p.data.brand }}</div>
          <div class="story-excerpt">{{ p.data.description | truncate(140) }}</div>
        </div>
        {% elif variant == 1 %}
        <div class="story" onclick="openDetail({{ idx }})">
          <div class="story-headline lg">{{ p.data.title }}</div>
          <div class="story-byline">{{ p.data.brand }} · {{ p.data.role }}</div>
          {{ thumb(p) }}
          <div class="story-excerpt">{{ p.data.description | truncate(100) }}</div>
        </div>
        {% else %}
        <div class="story" onclick="openDetail({{ idx }})">
          {{ thumb(p) }}
          <div class="story-headline md">{{ p.data.title }}</div>
          <div class="story-byline">{{ p.data.brand }}</div>
        </div>
        {% endif %}

        {% if loop.index0 == 0 %}
        <div class="whats-news">
          <div class="whats-news-title">Letters from the Editors</div>
          {% if letters | length > 0 %}
            {% for letter in letters %}{% if loop.index0 < 4 %}
            <a class="whats-news-item" href="/letters/{{ letter.fileSlug }}/">
              <div class="wn-headline">{{ letter.data.title }}</div>
              <div class="wn-client">{{ letter.data.date | dateDisplay }}</div>
            </a>
            {% endif %}{% endfor %}
          {% else %}
            <div style="font-family:var(--font-body);font-size:.78rem;color:var(--text);padding:5px 0;font-style:italic;">Coming soon...</div>
          {% endif %}
        </div>
        {% endif %}

      {% endfor %}
    </div>

    <div class="col-rule"></div>

    {# ——— CENTER COLUMN ——— #}
    <div class="col col-center">
      {% for p in centerProjects %}
        {% set idx = loop.index0 * 3 + 1 %}
        {% set variant = loop.index0 % 3 %}

        {% if variant == 0 %}
        <div class="story" onclick="openDetail({{ idx }})">
          <div class="story-kicker">{{ p.data.kicker }}</div>
          <div class="story-headline xl">{{ p.data.title }}</div>
          <div class="story-byline">{{ p.data.brand }} · {{ p.data.role }}</div>
          <div class="hero-media-wrapper">
            {% if loop.index0 == 0 and site.hero_video_url %}
              <iframe class="hero-video-iframe" src="{{ site.hero_video_url | videoEmbed }}?autoplay=1&mute=1&loop=1&playlist={{ site.hero_video_url | videoId }}&controls=0&playsinline=1&rel=0&showinfo=0&modestbranding=1" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen loading="lazy"></iframe>
            {% elif p.data.thumbnail_video_url %}
              <iframe class="hero-video-iframe" src="{{ p.data.thumbnail_video_url | videoEmbed }}?autoplay=1&mute=1&loop=1&playlist={{ p.data.thumbnail_video_url | videoId }}&controls=0&playsinline=1&rel=0&showinfo=0&modestbranding=1" frameborder="0" allow="autoplay; encrypted-media" loading="lazy"></iframe>
            {% else %}
              <img src="{{ p.data.thumbnail }}" alt="{{ p.data.title }}">
            {% endif %}
          </div>
          {% if p.data.thumbnail_caption %}<div class="story-caption">{{ p.data.thumbnail_caption }}</div>{% endif %}
          <div class="story-excerpt">{{ p.data.description }}</div>
        </div>

        {% elif variant == 1 %}
        <div class="story" onclick="openDetail({{ idx }})" style="border-top:1px solid var(--rule-light);padding-top:8px;">
          <div class="story-headline lg">{{ p.data.title }}</div>
          <div class="story-byline">{{ p.data.brand }} · {{ p.data.role }}</div>
          {{ thumb(p) }}
          {% if p.data.thumbnail_caption %}<div class="story-caption">{{ p.data.thumbnail_caption }}</div>{% endif %}
          <div class="story-excerpt">{{ p.data.description | truncate(180) }}</div>
        </div>

        {% else %}
        <div class="story" onclick="openDetail({{ idx }})" style="border-top:1px solid var(--rule-light);padding-top:8px;">
          <div class="story-kicker">{{ p.data.kicker }}</div>
          {{ thumb(p) }}
          <div class="story-headline lg">{{ p.data.title }}</div>
          <div class="story-byline">{{ p.data.brand }} · {{ p.data.role }}</div>
          <div class="story-excerpt">{{ p.data.description | truncate(140) }}</div>
        </div>
        {% endif %}

      {% endfor %}
    </div>

    <div class="col-rule"></div>

    {# ——— RIGHT COLUMN ——— #}
    <div class="col col-right">
      {% for p in rightProjects %}
        {% set idx = loop.index0 * 3 + 2 %}
        {% set variant = loop.index0 % 3 %}

        {% if variant == 0 %}
        <div class="story" onclick="openDetail({{ idx }})">
          <div class="story-kicker">{{ p.data.kicker }}</div>
          <div class="story-headline lg">{{ p.data.title }}</div>
          <div class="story-byline">{{ p.data.brand }}</div>
          {{ thumb(p) }}
          <div class="story-excerpt">{{ p.data.description | truncate(140) }}</div>
        </div>
        {% elif variant == 1 %}
        <div class="story" onclick="openDetail({{ idx }})" style="border-top:1px solid var(--rule-light);padding-top:8px;">
          <div class="story-headline md">{{ p.data.title }}</div>
          <div class="story-byline">{{ p.data.brand }} · {{ p.data.role }}</div>
          {{ thumb(p) }}
          {% if p.data.thumbnail_caption %}<div class="story-caption">{{ p.data.thumbnail_caption }}</div>{% endif %}
        </div>
        {% else %}
        <div class="story" onclick="openDetail({{ idx }})">
          {{ thumb(p) }}
          <div class="story-headline md">{{ p.data.title }}</div>
          <div class="story-byline">{{ p.data.brand }}</div>
          <div class="story-excerpt">{{ p.data.description | truncate(100) }}</div>
        </div>
        {% endif %}

      {% endfor %}

      <div style="border-top: 3px solid var(--text); padding-top: 6px; margin-top: 4px;">
        <div class="whats-news-title">Selected Clients</div>
        <div style="font-family: var(--font-body); font-size: 0.75rem; color: var(--text); line-height: 1.45;">{{ site.clients }}</div>
      </div>
    </div>

  </div>

  <footer class="colophon">
    <span>&copy; 2026 Ethan Byrne · Boston Polar Media</span>
    <div class="colophon-links">
      <a href="mailto:{{ site.email }}">{{ site.email }}</a>
      <a href="https://instagram.com/{{ site.instagram }}" target="_blank">@{{ site.instagram }}</a>
    </div>
  </footer>
</div>

{# DETAIL OVERLAY #}
<div class="detail-overlay" id="detailOverlay">
  <div class="detail-header-bar">
    <div class="detail-header-inner">
      <div class="detail-back" onclick="closeDetail()">&larr; Back to Front Page</div>
      <svg class="detail-masthead-svg" onclick="closeDetail()" viewBox="0 0 452.04 41.89" xmlns="http://www.w3.org/2000/svg" aria-label="EJSB">{% include "masthead-inner.svg" %}</svg>
      <div style="width: 120px;"></div>
    </div>
  </div>
  <div class="detail-content" id="detailContent"></div>
</div>

{# Embed project data as JSON for detail overlay #}
<script>
var PROJECTS = [
{% for p in allProjects %}
  { name: {{ p.data.title | dump | safe }}, brand: {{ p.data.brand | dump | safe }}, role: {{ p.data.role | dump | safe }}, kicker: {{ p.data.kicker | dump | safe }}, description: {{ p.data.description | dump | safe }}, videoUrl: {{ (p.data.video_url or "") | dump | safe }}, videos: [{% if p.data.videos %}{% for v in p.data.videos %}{url:{{ v.url | dump | safe }},caption:{{ (v.caption or "") | dump | safe }}}{% if not loop.last %},{% endif %}{% endfor %}{% endif %}], images: [{% for img in p.data.images %}"{{ img.url }}"{% if not loop.last %},{% endif %}{% endfor %}], imageAspects: [{% for img in p.data.images %}"{{ img.aspect | default('landscape') }}"{% if not loop.last %},{% endif %}{% endfor %}] }{% if not loop.last %},{% endif %}
{% endfor %}
];

document.getElementById('currentDate').textContent = new Date().toLocaleDateString('en-US', { weekday: 'long', year: 'numeric', month: 'long', day: 'numeric' });

function openDetail(idx) {
  var p = PROJECTS[idx];
  if (!p) return;
  var overlay = document.getElementById('detailOverlay');
  var content = document.getElementById('detailContent');

  var videoHTML = '';
  var allVideos = [];
  if (p.videos && p.videos.length > 0) {
    p.videos.forEach(function(v) { allVideos.push({url: v.url, caption: v.caption}); });
  }
  if (allVideos.length === 0 && p.videoUrl) {
    allVideos.push({url: p.videoUrl, caption: ''});
  }
  allVideos.forEach(function(v) {
    var embedSrc = parseVideoUrl(v.url);
    if (embedSrc) {
      var vid = v.url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
      var playlist = vid ? '&playlist=' + vid[1] : '';
      videoHTML += '<div class="detail-video-wrapper"><iframe src="' + embedSrc + '?autoplay=1&mute=1&loop=1' + playlist + '&rel=0&modestbranding=1&playsinline=1" frameborder="0" allow="autoplay; encrypted-media" allowfullscreen></iframe></div>';
      if (v.caption) {
        videoHTML += '<div class="detail-video-caption">' + v.caption + '</div>';
      }
    }
  });

  var galleryHTML = '';
  var i = 0;
  while (i < p.images.length) {
    var src = p.images[i];
    var aspect = (p.imageAspects && p.imageAspects[i]) || 'landscape';
    var nextAspect = (i + 1 < p.images.length && p.imageAspects) ? p.imageAspects[i + 1] : 'landscape';
    if (aspect === 'portrait' && nextAspect === 'portrait' && i + 1 < p.images.length) {
      galleryHTML += '<div class="detail-gallery-pair"><img src="' + src + '" alt="' + p.name + '"><img src="' + p.images[i+1] + '" alt="' + p.name + '"></div>';
      i += 2;
    } else if (aspect === 'portrait') {
      galleryHTML += '<div class="detail-gallery-portrait"><img src="' + src + '" alt="' + p.name + '"></div>';
      i++;
    } else {
      galleryHTML += '<div><img src="' + src + '" alt="' + p.name + '"></div>';
      i++;
    }
  }

  content.innerHTML = '<div class="detail-kicker">' + p.kicker + '</div><div class="detail-title">' + p.name + '</div><div class="detail-byline-block"><div class="detail-client">' + p.brand + ' · ' + p.role + '</div><div class="detail-date">2024–2025</div></div><div class="detail-description">' + p.description + '</div>' + videoHTML + '<div class="detail-gallery">' + galleryHTML + '</div>';
  overlay.classList.add('active');
  overlay.scrollTop = 0;
  document.body.style.overflow = 'hidden';
}

function parseVideoUrl(url) {
  if (!url) return null;
  var ytMatch = url.match(/(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)([a-zA-Z0-9_-]{11})/);
  if (ytMatch) return 'https://www.youtube.com/embed/' + ytMatch[1];
  var vmMatch = url.match(/vimeo\.com\/(\d+)/);
  if (vmMatch) return 'https://player.vimeo.com/video/' + vmMatch[1];
  return null;
}
function closeDetail() { document.getElementById('detailOverlay').classList.remove('active'); document.body.style.overflow = ''; }
document.addEventListener('keydown', function(e) { if (e.key === 'Escape') closeDetail(); });

(function() {
  var FINNHUB_KEY = 'd75hic1r01qk56kcqbl0d75hic1r01qk56kcqblg';
  var symbols = ['DIA','QQQ','SPY','TLT','USO','GLD','FXE','FXY'];
  var prefixes = {DIA:'$',QQQ:'',SPY:'',TLT:'',USO:'$',GLD:'$',FXE:'$',FXY:''};
  if (!FINNHUB_KEY) return;
  symbols.forEach(function(sym) {
    fetch('https://finnhub.io/api/v1/quote?symbol=' + sym + '&token=' + FINNHUB_KEY)
      .then(function(r) { return r.json(); })
      .then(function(d) {
        if (!d || !d.c) return;
        var valEl = document.getElementById('t-' + sym);
        var chgEl = document.getElementById('tc-' + sym);
        if (!valEl) return;
        valEl.textContent = (prefixes[sym] || '') + d.c.toLocaleString(undefined, {minimumFractionDigits:2, maximumFractionDigits:2});
        if (d.d !== null && d.d !== undefined) {
          var isUp = d.d >= 0;
          chgEl.className = 'ticker-chg ' + (isUp ? 'ticker-up' : 'ticker-down');
          chgEl.innerHTML = '<span class="ticker-tri">' + (isUp ? '▲' : '▼') + '</span>' + Math.abs(d.dp).toFixed(1) + '%';
        }
      })
      .catch(function() {});
  });
})();
</script>
