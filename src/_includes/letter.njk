<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{{ title }} — EJSB</title>
<meta name="description" content="{{ excerpt or title }}">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,600&family=Libre+Franklin:wght@400;500;600;700;800&family=Barlow+Condensed:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://use.typekit.net/sau1eeb.css">
<style>
:root{--black:#1a1a1a;--text:#1a1a1a;--rule-light:#b0b0b0;--bg:#f7f5f0;--white:#fff;--font-masthead:'kepler-std',Georgia,'Times New Roman',serif;--font-headline:'kepler-std','Cormorant Garamond',Georgia,serif;--font-body:'Source Serif 4',Georgia,serif;--font-sans:'Libre Franklin','Helvetica Neue',Helvetica,sans-serif;--font-condensed:'Barlow Condensed','Arial Narrow',sans-serif;--page-max:1200px;--page-pad:32px}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{font-size:14px;-webkit-font-smoothing:antialiased}
body{font-family:var(--font-body);color:var(--text);background:var(--bg);line-height:1.3}
a{color:inherit;text-decoration:none}
img{max-width:100%;display:block}
.letter-header-bar{position:sticky;top:0;z-index:10;background:var(--bg);border-bottom:1px solid var(--rule-light)}
.letter-header-inner{max-width:var(--page-max);margin:0 auto;padding:8px var(--page-pad);display:flex;justify-content:space-between;align-items:center}
.letter-back{font-family:var(--font-condensed);font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;cursor:pointer;color:var(--text);transition:opacity .2s}
.letter-back:hover{opacity:.6}
.letter-masthead-svg{width:40%;max-width:360px;height:auto;display:block;cursor:pointer;overflow:visible}
.letter-content{max-width:680px;margin:0 auto;padding:40px var(--page-pad) 80px}
.letter-kicker{font-family:var(--font-condensed);font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--text);margin-bottom:4px}
.letter-title{font-family:var(--font-headline);font-size:2.6rem;font-weight:500;line-height:1.05;letter-spacing:-1px;color:var(--text);margin-bottom:8px}
.letter-date{font-family:var(--font-condensed);font-size:.7rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--text);padding-bottom:10px;border-bottom:1px solid var(--rule-light);margin-bottom:20px}
.letter-body{font-family:var(--font-body);font-size:1rem;line-height:1.55;color:var(--text)}
.letter-body p{margin-bottom:14px;text-align:justify}
.letter-body p:first-of-type::first-letter{font-family:var(--font-headline);font-size:3rem;font-weight:600;float:left;line-height:.8;margin-right:6px;margin-top:4px;color:var(--text)}
.letter-body img{width:100%;margin:20px 0;display:block}
.letter-body h2,.letter-body h3{font-family:var(--font-headline);font-weight:600;margin:24px 0 8px}
.letter-body blockquote{border-left:3px solid var(--text);padding-left:16px;margin:16px 0;font-style:italic}
@media(max-width:800px){:root{--page-pad:16px}.letter-title{font-size:1.6rem}.letter-masthead-svg{width:50%}}
</style>
</head>
<body>
  <div class="letter-header-bar">
    <div class="letter-header-inner">
      <a class="letter-back" href="/">&larr; Back to Front Page</a>
      <a href="/"><svg class="letter-masthead-svg" viewBox="0 0 452.04 41.89" xmlns="http://www.w3.org/2000/svg" aria-label="EJSB">{% include "masthead-inner.svg" %}</svg></a>
      <div style="width: 120px;"></div>
    </div>
  </div>
  <div class="letter-content">
    <div class="letter-kicker">Letters from the Editors</div>
    <div class="letter-title">{{ title }}</div>
    <div class="letter-date">{{ date | dateDisplay }}</div>
    <div class="letter-body">
      {{ content | safe }}
    </div>
  </div>
</body>
</html>
