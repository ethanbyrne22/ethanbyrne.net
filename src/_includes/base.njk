<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EJSB — Ethan Byrne</title>
<meta name="description" content="Ethan Byrne is a Director of Photography, photographer, and editor based in New York City.">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;0,700;1,300;1,400;1,500&family=Source+Serif+4:ital,opsz,wght@0,8..60,300;0,8..60,400;0,8..60,600;0,8..60,700;1,8..60,400;1,8..60,600&family=Libre+Franklin:wght@400;500;600;700;800&family=Barlow+Condensed:wght@400;500;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://use.typekit.net/sau1eeb.css">
<script src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
<style>
:root{--black:#1a1a1a;--text:#1a1a1a;--rule-light:#b0b0b0;--bg:#f7f5f0;--white:#fff;--red:#990000;--green:#0a7c2e;--font-masthead:'kepler-std',Georgia,'Times New Roman',serif;--font-headline:'kepler-std','Cormorant Garamond',Georgia,serif;--font-body:'Source Serif 4',Georgia,serif;--font-sans:'Libre Franklin','Helvetica Neue',Helvetica,sans-serif;--font-condensed:'Barlow Condensed','Arial Narrow',sans-serif;--col-gap:18px;--rule-width:1.5px;--page-max:1200px;--page-pad:32px}
*,*::before,*::after{margin:0;padding:0;box-sizing:border-box}
html{font-size:14px;-webkit-font-smoothing:antialiased;-moz-osx-font-smoothing:grayscale}
body{font-family:var(--font-body);color:var(--text);background:var(--bg);line-height:1.3}
a{color:inherit;text-decoration:none}
img,video{max-width:100%;display:block}
.front-page{max-width:var(--page-max);margin:0 auto;padding:0 var(--page-pad)}
.masthead{text-align:center;padding:14px 0 4px;border-bottom:2px solid var(--text);position:relative}
.masthead-svg{display:block;width:80%;max-width:960px;margin:0 auto;height:auto;cursor:pointer}
.masthead-subtitle{font-family:var(--font-masthead);font-size:.72rem;font-weight:600;letter-spacing:3.5px;text-transform:uppercase;color:var(--text);margin-top:14px;margin-bottom:8px}
.dateline-bar{display:flex;justify-content:space-between;align-items:center;padding:4px 0;font-family:var(--font-condensed);font-size:.78rem;font-weight:600;letter-spacing:.8px;color:var(--text);text-transform:uppercase;border-bottom:1px solid var(--rule-light)}
.dateline-bar a{transition:opacity .2s}
.dateline-bar a:hover{opacity:.6}
.dateline-stars{font-size:.82rem;letter-spacing:1px}
.ticker-bar{display:flex;align-items:center;justify-content:center;gap:0;padding:4px 0;font-family:var(--font-condensed);font-size:.68rem;font-weight:600;letter-spacing:.3px;color:var(--text);border-bottom:1px solid var(--rule-light);white-space:nowrap;text-transform:uppercase;width:100%}
.ticker-item{display:inline-flex;align-items:center;gap:3px;padding:0 10px;border-right:1px solid var(--rule-light);flex-shrink:0}
.ticker-item:last-child{border-right:none}
.ticker-label{font-weight:700}
.ticker-val{font-weight:600}
.ticker-chg{font-weight:700}
.ticker-down{color:var(--red)}
.ticker-up{color:var(--green)}
.ticker-tri{font-size:.5rem;margin-right:1px}
.main-grid{display:grid;grid-template-columns:1.1fr var(--rule-width) 1.8fr var(--rule-width) 1.1fr;gap:0;padding-top:10px}
.col-rule{background:var(--rule-light);width:var(--rule-width)}
.col-left{padding-right:var(--col-gap)}
.col-center{padding:0 var(--col-gap)}
.col-right{padding-left:var(--col-gap)}
.story{margin-bottom:12px;cursor:pointer;transition:opacity .2s}
.story:hover{opacity:.75}
.story-kicker{font-family:var(--font-condensed);font-size:.65rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--text);margin-bottom:2px}
.story-headline{font-family:var(--font-headline);font-weight:600;color:var(--text);line-height:1.08;margin-bottom:3px}
.story-headline.xl{font-size:2rem;letter-spacing:-.8px}
.story-headline.lg{font-size:1.45rem;letter-spacing:-.3px}
.story-headline.md{font-size:1.1rem}
.story-headline.sm{font-size:.9rem;font-weight:500}
.story-byline{font-family:var(--font-condensed);font-size:.65rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--text);margin-bottom:3px}
.story-excerpt{font-family:var(--font-body);font-size:.82rem;line-height:1.32;color:var(--text);text-align:justify}
.story-image{width:100%;aspect-ratio:16/10;object-fit:cover;margin-bottom:5px}
.story-image.portrait{aspect-ratio:3/4}
.story-image.square{aspect-ratio:1/1}
.story-caption{font-family:var(--font-sans);font-size:.6rem;color:var(--text);margin-top:2px;margin-bottom:6px;line-height:1.25}
.hero-media-wrapper{width:100%;aspect-ratio:16/10;overflow:hidden;margin-bottom:5px;position:relative;background:#111}
.hero-media-wrapper img,.hero-media-wrapper video{width:100%;height:100%;object-fit:cover}
.hero-media-wrapper iframe.hero-video-iframe{width:100%;height:100%;border:none;object-fit:cover}
.detail-video-wrapper{position:relative;width:100%;padding-bottom:56.25%;margin-bottom:16px;background:#111}
.detail-video-wrapper iframe{position:absolute;top:0;left:0;width:100%;height:100%;border:none}
.whats-news{border-top:3px solid var(--text);padding-top:6px;margin-top:2px}
.whats-news-title{font-family:var(--font-headline);font-size:.95rem;font-weight:600;margin-bottom:6px;color:var(--text)}
.whats-news-item{padding:5px 0;border-top:1px solid var(--rule-light);cursor:pointer;transition:opacity .2s}
.whats-news-item:hover{opacity:.7}
.whats-news-item .wn-headline{font-family:var(--font-body);font-size:.78rem;font-weight:600;color:var(--text);line-height:1.25;margin-bottom:1px}
.whats-news-item .wn-client{font-family:var(--font-condensed);font-size:.6rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;color:var(--text)}
.below-fold{border-top:1px solid var(--rule-light);padding-top:10px;margin-top:6px}
.below-fold-grid{display:grid;grid-template-columns:1fr var(--rule-width) 1fr var(--rule-width) 1fr;gap:0}
.below-fold-grid .col-rule{background:var(--rule-light)}
.bf-story{padding:0 var(--col-gap);cursor:pointer;transition:opacity .2s}
.bf-story:first-child{padding-left:0}
.bf-story:last-child{padding-right:0}
.bf-story:hover{opacity:.75}
.bf-story .story-image{aspect-ratio:3/2}
.bf-story .story-excerpt{text-align:justify}
.colophon{border-top:2px solid var(--text);margin-top:16px;padding:10px 0 32px;display:flex;justify-content:space-between;align-items:center;font-family:var(--font-condensed);font-size:.78rem;font-weight:600;letter-spacing:.8px;color:var(--text);text-transform:uppercase}
.colophon a{transition:opacity .2s}
.colophon a:hover{opacity:.6}
.colophon-links{display:flex;gap:18px}
.detail-overlay,.about-overlay{position:fixed;inset:0;background:var(--bg);z-index:10000;opacity:0;visibility:hidden;transition:opacity .35s ease,visibility .35s ease;overflow-y:auto}
.detail-overlay.active,.about-overlay.active{opacity:1;visibility:visible}
.detail-header-bar{position:sticky;top:0;z-index:10;background:var(--bg);border-bottom:1px solid var(--rule-light)}
.detail-header-inner{max-width:var(--page-max);margin:0 auto;padding:8px var(--page-pad);display:flex;justify-content:space-between;align-items:center}
.detail-back{font-family:var(--font-condensed);font-size:.75rem;font-weight:600;text-transform:uppercase;letter-spacing:1px;cursor:pointer;color:var(--text);transition:opacity .2s;flex-shrink:0}
.detail-back:hover{opacity:.6}
.detail-masthead-svg{width:40%;max-width:360px;height:auto;display:block;cursor:pointer;overflow:visible}
.detail-content{max-width:900px;margin:0 auto;padding:28px var(--page-pad) 60px}
.detail-content .detail-kicker{font-family:var(--font-condensed);font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--text);margin-bottom:4px}
.detail-content .detail-title{font-family:var(--font-headline);font-size:2.6rem;font-weight:500;line-height:1.05;letter-spacing:-1px;color:var(--text);margin-bottom:8px}
.detail-content .detail-byline-block{display:flex;align-items:center;gap:12px;padding-bottom:10px;border-bottom:1px solid var(--rule-light);margin-bottom:16px}
.detail-content .detail-client{font-family:var(--font-condensed);font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1px;color:var(--text)}
.detail-content .detail-date{font-family:var(--font-condensed);font-size:.65rem;font-weight:500;color:var(--text);text-transform:uppercase;letter-spacing:.5px}
.detail-content .detail-description{font-family:var(--font-body);font-size:1rem;line-height:1.4;color:var(--text);margin-bottom:24px;max-width:640px;text-align:justify}
.detail-content .detail-description::first-letter{font-family:var(--font-headline);font-size:3rem;font-weight:600;float:left;line-height:.8;margin-right:6px;margin-top:4px;color:var(--text)}
.detail-gallery{display:flex;flex-direction:column;gap:16px}
.detail-gallery img,.detail-gallery video{width:100%;display:block}
.about-content{max-width:900px;margin:0 auto;padding:28px var(--page-pad) 60px}
.about-content .about-section-label{font-family:var(--font-condensed);font-size:.7rem;font-weight:700;text-transform:uppercase;letter-spacing:1.5px;color:var(--text);margin-bottom:4px}
.about-content .about-name{font-family:var(--font-headline);font-size:2.6rem;font-weight:500;line-height:1.05;letter-spacing:-1px;color:var(--text);margin-bottom:4px}
.about-content .about-title{font-family:var(--font-condensed);font-size:.8rem;font-weight:600;text-transform:uppercase;letter-spacing:1.5px;color:var(--text);margin-bottom:14px;padding-bottom:10px;border-bottom:1px solid var(--rule-light)}
.about-two-col{display:grid;grid-template-columns:1.2fr 1fr;gap:32px;margin-bottom:32px}
.about-bio{font-family:var(--font-body);font-size:.93rem;line-height:1.4;color:var(--text);text-align:justify}
.about-bio p{margin-bottom:10px}
.about-bio::first-letter{font-family:var(--font-headline);font-size:3rem;font-weight:600;float:left;line-height:.8;margin-right:6px;margin-top:4px;color:var(--text)}
.about-photo{width:100%;aspect-ratio:3/4;object-fit:cover;margin-bottom:16px;background:#ddd}
.about-sidebar-heading{font-family:var(--font-headline);font-size:1rem;font-weight:600;color:var(--text);margin-bottom:6px;padding-bottom:4px;border-bottom:2px solid var(--text)}
.about-sidebar-section{margin-bottom:16px}
.about-sidebar-section p,.about-sidebar-section a{font-family:var(--font-body);font-size:.82rem;line-height:1.4;color:var(--text)}
.about-sidebar-section a{text-decoration:underline;text-underline-offset:2px;transition:opacity .2s}
.about-sidebar-section a:hover{opacity:.6}
.about-clients-list{font-family:var(--font-body);font-size:.82rem;line-height:1.5;color:var(--text)}
@media(max-width:800px){:root{--page-pad:16px;--col-gap:12px}.masthead-svg{width:92%}.masthead-subtitle{font-size:.55rem;letter-spacing:1.5px}.dateline-bar{font-size:.62rem}.ticker-bar{font-size:.52rem;overflow-x:auto;justify-content:flex-start}.main-grid{display:flex;flex-direction:column;gap:0}.col-rule{display:none}.col-left,.col-center,.col-right{padding:0;border-bottom:1px solid var(--rule-light);padding-bottom:12px;margin-bottom:12px}.col-center{order:-1}.story-headline.xl{font-size:1.5rem}.story-headline.lg{font-size:1.2rem}.below-fold-grid{display:flex;flex-direction:column;gap:0}.below-fold-grid .col-rule{display:none}.bf-story{padding:0 0 12px 0;margin-bottom:12px;border-bottom:1px solid var(--rule-light)}.detail-content .detail-title{font-size:1.6rem}.detail-content{padding:20px var(--page-pad) 48px}.detail-masthead-svg{width:50%}.about-two-col{grid-template-columns:1fr;gap:20px}.about-content .about-name{font-size:1.6rem}}
@keyframes fadeInUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:translateY(0)}}
.main-grid,.below-fold{animation:fadeInUp .5s ease both}
.below-fold{animation-delay:.1s}
</style>
</head>
<body>
{{ content | safe }}

<script>
// Netlify Identity redirect after login
if (window.netlifyIdentity) {
  window.netlifyIdentity.on("init", function(user) {
    if (!user) { window.netlifyIdentity.on("login", function() { document.location.href = "/admin/"; }); }
  });
}
</script>
</body>
</html>
